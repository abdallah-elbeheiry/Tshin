<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Tshin.ViewModels"
             x:Class="Tshin.Views.MainMenuView"
             x:DataType="vm:MainMenuViewModel">
    <Panel Background="{StaticResource DarkBackground}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
            <TextBlock Text="TSHIN" FontSize="72" FontWeight="Bold" HorizontalAlignment="Center">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#6A1B9A" Offset="0" />
                        <GradientStop Color="#AD1457" Offset="1" />
                    </LinearGradientBrush>
                </TextBlock.Foreground>
            </TextBlock>
            
            <Button Content="PLAY" Command="{Binding PlayCommand}" Width="200" HorizontalContentAlignment="Center" Classes="primary" FontSize="20" Padding="15"/>
            <Button Content="CREATE" Command="{Binding CreateCommand}" Width="200" HorizontalContentAlignment="Center" Classes="secondary" FontSize="20" Padding="15"/>
            <Button Content="EXIT" Command="{Binding ExitCommand}" Width="200" HorizontalContentAlignment="Center" Classes="accent" FontSize="20" Padding="15"/>
        </StackPanel>
    </Panel>
</UserControl>
